#!/bin/bash
# Full emotion steering sweep â€” ALL 171 extracted emotions.
# Slurm job array: each task steers a 43-emotion chunk of steering_all_traits.txt
# (171 traits / 43 = 4 tasks, array 0-3), so chunks backfill across free h200s
# and a single chunk timing out doesn't lose the others (results.jsonl is resumable).
# Sized to the QOS caps: MaxSubmitPU=8, MaxJobsPU=4 â€” 4 array tasks fit under both and
# can all run at once. Gate: submit with --dependency=afterok:<smoke_jobid> so the sweep
# only runs once the smoke (slurm/steering_smoke.sbatch) has validated the pipeline.
# Submit from repo root:
#   sbatch --dependency=afterok:<smoke_jobid> slurm/steering_all.sbatch
#SBATCH --job-name=ti_steer_all
#SBATCH --partition=multigpu
#SBATCH --array=0-3
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=96G
#SBATCH --gres=gpu:h200:1
#SBATCH --time=06:00:00
#SBATCH --output=/scratch/%u/traitinterp/logs/%x_%A_%a.out
#SBATCH --error=/scratch/%u/traitinterp/logs/%x_%A_%a.err

set -euo pipefail
CONDA_BASE=/shared/EL9/explorer/miniconda3/25.9.1/miniconda3
ENV_PREFIX=/scratch/$USER/conda_envs/traitinterp
REPO=/scratch/$USER/traitinterp
CHUNK=43

echo "==== ti_steer_all A=$SLURM_ARRAY_JOB_ID task=$SLURM_ARRAY_TASK_ID on $(hostname) GPU=$CUDA_VISIBLE_DEVICES $(date) ===="
source "$CONDA_BASE/etc/profile.d/conda.sh"
conda activate "$ENV_PREFIX"

export HF_HOME=/scratch/$USER/hf_cache
[ -f "$HOME/.config/traitinterp/env" ] && source "$HOME/.config/traitinterp/env"
# Judge via Anthropic claude-sonnet-4-5 (matches Sofroniew et al. 2026), not the quota-exhausted
# OpenAI key. Needs ANTHROPIC_API_KEY in ~/.config/traitinterp/env (sourced above).
export TRAIT_JUDGE_PROVIDER=anthropic

cd "$REPO"

# This task's slice of the 171-trait list (1-indexed line range).
START=$(( SLURM_ARRAY_TASK_ID * CHUNK + 1 ))
END=$(( START + CHUNK - 1 ))
TRAITS=$(sed -n "${START},${END}p" steering_all_traits.txt | paste -sd, -)
if [ -z "$TRAITS" ]; then
    echo "No traits for task $SLURM_ARRAY_TASK_ID (lines $START-$END) â€” nothing to do."
    exit 0
fi
echo "---- task $SLURM_ARRAY_TASK_ID: traits (lines $START-$END) ----"
echo "$TRAITS" | tr ',' '\n'

# mean_diff+gm vectors; per-emotion steering.json (generic neutral questions, generated by
# gen_steering_json.py) supplies the prompt set; generic judge; layers 25-49 (30-60% depth).
# resolve_questions() hard-requires steering.json per trait, so we rely on it rather than
# --questions-file (that path still called load_steering_data and crashed without steering.json).
python steering/run_steering_eval.py \
    --experiment ant_emotion_concepts \
    --traits "$TRAITS" \
    --method mean_diff+gm \
    --component residual \
    --no-custom-prompt \
    --layers 25,31,37,43,49 \
    --search-steps 5 \
    --subset 5 \
    --max-new-tokens 64 \
    --save-responses best \
    --load-in-4bit
RC=$?
echo "==== ti_steer_all task $SLURM_ARRAY_TASK_ID exit=$RC $(date) ===="
exit $RC   # propagate the real exit code so a crash shows as FAILED, not fake-COMPLETED
