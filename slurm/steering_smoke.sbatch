#!/bin/bash
# Steering SMOKE test — validate the emotion-steering pipeline end-to-end, cheaply.
# One emotion (happy), one layer (49 = headline layer), 2 search steps.
# Exercises: fresh mean_diff+gm vector load, SteeringHook add-to-residual, adaptive
# coefficient search, and the OpenAI TraitJudge (coherence + trait score). ~10-15 min
# incl. 4-bit 70B load. If this passes, slurm/steering_emotion.sbatch (11 emotions) is safe.
# Submit from repo root:  sbatch slurm/steering_smoke.sbatch
#SBATCH --job-name=ti_steer_smoke
#SBATCH --partition=gpu
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=96G
#SBATCH --gres=gpu:h200:1
#SBATCH --time=01:00:00
#SBATCH --output=/scratch/%u/traitinterp/logs/%x_%j.out
#SBATCH --error=/scratch/%u/traitinterp/logs/%x_%j.err

set -uo pipefail
CONDA_BASE=/shared/EL9/explorer/miniconda3/25.9.1/miniconda3
ENV_PREFIX=/scratch/$USER/conda_envs/traitinterp
REPO=/scratch/$USER/traitinterp

echo "==== ti_steer_smoke $SLURM_JOB_ID on $(hostname) GPU=$CUDA_VISIBLE_DEVICES $(date) ===="
source "$CONDA_BASE/etc/profile.d/conda.sh"
conda activate "$ENV_PREFIX"

# Secrets (HF_TOKEN + OPENAI_API_KEY for the judge) + caches — kept out of git
export HF_HOME=/scratch/$USER/hf_cache
[ -f "$HOME/.config/traitinterp/env" ] && source "$HOME/.config/traitinterp/env"
# Judge via Anthropic claude-sonnet-4-5 (matches Sofroniew et al. 2026), not the quota-exhausted
# OpenAI key. Needs ANTHROPIC_API_KEY in ~/.config/traitinterp/env (sourced above).
export TRAIT_JUDGE_PROVIDER=anthropic
python - <<'PY'
import os; print("OPENAI key present:", bool(os.environ.get("OPENAI_API_KEY")))
import torch; print("CUDA avail:", torch.cuda.is_available())
PY

cd "$REPO"

echo "---- Steering smoke: happy @ layer 49, 2 search steps ----"
# --method mean_diff+gm: vectors were extracted with mean_diff+gm, not the default 'probe'.
# Prompts come from the per-emotion steering.json (generated by gen_steering_json.py) —
# resolve_questions() hard-requires it; --no-custom-prompt uses the generic judge prompt.
python steering/run_steering_eval.py \
    --experiment ant_emotion_concepts \
    --traits "ant_emotion_concepts/happy" \
    --method mean_diff+gm \
    --component residual \
    --no-custom-prompt \
    --layers 49 \
    --search-steps 2 \
    --subset 3 \
    --max-new-tokens 64 \
    --load-in-4bit
RC=$?
echo "==== steering smoke exit=$RC $(date) ===="
exit $RC   # propagate real exit code (no fake-COMPLETED)
echo "Results: $REPO/experiments/ant_emotion_concepts/steering/  (results.jsonl per trait)"
